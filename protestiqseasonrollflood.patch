+const SUBJECT_SELECT =
+  'propid,situsconcat,situsstreetname,situsbldgnum,currvalappraised,currvalmarket,' +
+  'currvalland,currvalimprv,imprvmainarea,imprvyearbuilt,nbhdcode,marketareacode,' +
